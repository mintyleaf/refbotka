REFBOTKA_BOT_TOKEN=your-telegram-bot-token

# SQLite by default; use postgresql+asyncpg://... for Postgres
REFBOTKA_DATABASE_URL=sqlite+aiosqlite:///./refbotka.db

# Refinance API (see refinance project secrets.env.example)
REFBOTKA_REFINANCE_API_URL=http://localhost:8000
REFBOTKA_REFINANCE_SECRET_KEY=your-refinance-secret-key
REFBOTKA_REFINANCE_BOT_ENTITY_ID=1

# Comma-separated Telegram IDs that get resident tier on first interaction
REFBOTKA_BOOTSTRAP_RESIDENT_IDS=
