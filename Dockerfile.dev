FROM ghcr.io/astral-sh/uv:python3.12-alpine AS builder

WORKDIR /app

ENV UV_CACHE_DIR=/root/.cache/uv \
    UV_LINK_MODE=copy \
    VIRTUAL_ENV=/venv \
    PATH="/venv/bin:$PATH"

# botka provided via: --build-context botka=../botka
COPY --from=botka . /botka/

RUN uv venv /venv

COPY pyproject.toml /app/
COPY src /app/src

# Rewrite the local path (../botka) to the in-container path (/botka)
RUN sed -i 's|path = "\.\./botka"[^}]*|path = "/botka"|' pyproject.toml

RUN --mount=type=cache,target=/root/.cache/uv \
    uv pip install .


FROM python:3.12-alpine

ENV PATH="/venv/bin:$PATH"

COPY --from=builder /venv /venv

CMD ["refbotka"]
